# Скопируйте в .env (локально) или задайте как Environment Variables на Render.
# НЕ коммитьте реальный .env в git.

# --- Telegram-бот (см. README, раздел "Telegram") ---
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=ваш_числовой_chat_id

# --- Поведение ---
# loop = крутиться постоянно (для сервера/Render); once = один прогон (для cron)
RUN_MODE=loop
# Интервал проверки в минутах (переопределяет config.yaml)
CHECK_INTERVAL_MINUTES=20
